<view class="container">
  <view class="section">
    <text class="section-title">基本信息</text>
    <view class="avatar-uploader" bindtap="chooseAvatar">
      <image wx:if="{{card.avatar}}" class="avatar-preview" src="{{card.avatar}}" mode="aspectFill" />
      <view wx:else class="avatar-empty"><text class="plus">+</text><text>上传照片</text></view>
    </view>
    <view class="form-item"><text class="label">姓名 *</text><input class="input" value="{{card.name}}" data-field="name" bindinput="setField" placeholder="请输入姓名" /></view>
    <view class="form-item"><text class="label">性别</text><picker mode="selector" range="{{genders}}" range-key="label" bindchange="onGenderChange"><view class="picker">{{card.gender || '未设置'}}</view></picker></view>
    <view class="form-item"><text class="label">公开</text><switch checked="{{card.isPublic}}" bindchange="onPublicChange" /></view>
  </view>

  <view class="section">
    <text class="section-title">工作信息</text>
    <view class="form-item"><text class="label">工作单位</text><input class="input" value="{{card.company}}" data-field="company" bindinput="setField" /></view>
    <view class="form-item"><text class="label">职位</text><input class="input" value="{{card.position}}" data-field="position" bindinput="setField" /></view>
    <view class="form-item"><text class="label">行业</text><input class="input" value="{{card.industry}}" data-field="industry" bindinput="setField" /></view>
    <view class="form-item"><text class="label">领域</text><input class="input" value="{{card.field}}" data-field="field" bindinput="setField" /></view>
  </view>

  <view class="section">
    <view class="section-head"><text class="section-title no-border">手机</text><view class="circle-add" bindtap="addPhone">+</view></view>
    <view class="array-row" wx:for="{{card.phones}}" wx:key="index">
      <input class="input" value="{{item}}" data-index="{{index}}" bindinput="onPhoneInput" placeholder="电话" />
      <view class="small-btn muted" data-index="{{index}}" bindtap="removePhone">删</view>
    </view>
    <view class="section-head mt"><text class="section-title no-border">邮箱</text><view class="circle-add" bindtap="addEmail">+</view></view>
    <view class="array-row" wx:for="{{card.emails}}" wx:key="index">
      <input class="input" value="{{item}}" data-index="{{index}}" bindinput="onEmailInput" placeholder="邮箱" />
      <view class="small-btn muted" data-index="{{index}}" bindtap="removeEmail">删</view>
    </view>
    <view class="form-item"><text class="label">微信</text><input class="input" value="{{card.wechat}}" data-field="wechat" bindinput="setField" /></view>
    <view class="form-item"><text class="label">QQ</text><input class="input" value="{{card.qq}}" data-field="qq" bindinput="setField" /></view>
  </view>

  <view class="section">
    <text class="section-title">生日与身份</text>
    <view class="form-item"><text class="label">阳历生日</text><picker mode="date" value="{{card.solarBirthday}}" bindchange="onSolarBirthdayChange"><view class="picker">{{card.solarBirthday || '选择日期'}}</view></picker></view>
    <view class="form-item"><text class="label">农历生日</text><input class="input" value="{{card.lunarBirthday}}" data-field="lunarBirthday" bindinput="setField" placeholder="如 腊月初八" /></view>
    <view class="form-item"><text class="label">民族</text><input class="input" value="{{card.ethnicity}}" data-field="ethnicity" bindinput="setField" /></view>
    <view class="form-item"><text class="label">籍贯</text><input class="input" value="{{card.birthplace}}" data-field="birthplace" bindinput="setField" /></view>
    <view class="form-item"><text class="label">婚姻</text><picker mode="selector" range="{{marriages}}" range-key="label" bindchange="onMarriageChange"><view class="picker">{{card.maritalStatus || '未设置'}}</view></picker></view>
  </view>

  <view class="section">
    <text class="section-title">地址</text>
    <view class="form-item"><text class="label">省</text><input class="input" value="{{card.province}}" data-field="province" bindinput="setField" /></view>
    <view class="form-item"><text class="label">市</text><input class="input" value="{{card.city}}" data-field="city" bindinput="setField" /></view>
    <view class="form-item"><text class="label">区/县</text><input class="input" value="{{card.district}}" data-field="district" bindinput="setField" /></view>
    <view class="form-item"><text class="label">街道/乡镇</text><input class="input" value="{{card.township}}" data-field="township" bindinput="setField" /></view>
    <view class="form-item"><text class="label">详细地址</text><input class="input" value="{{card.detailAddress}}" data-field="detailAddress" bindinput="setField" /></view>
  </view>

  <view class="section">
    <view class="section-head"><text class="section-title no-border">教育经历</text><view class="circle-add" bindtap="addEducation">+</view></view>
    <view class="experience-form" wx:for="{{card.educationBackground}}" wx:key="index">
      <view class="year-row"><input class="input" placeholder="开始年" value="{{item.startYear}}" data-index="{{index}}" data-field="startYear" bindinput="setEducationField" /><input class="input" placeholder="结束年" value="{{item.endYear}}" data-index="{{index}}" data-field="endYear" bindinput="setEducationField" /></view>
      <input class="input" placeholder="学校" value="{{item.school}}" data-index="{{index}}" data-field="school" bindinput="setEducationField" />
      <input class="input" placeholder="学历/学位" value="{{item.degree}}" data-index="{{index}}" data-field="degree" bindinput="setEducationField" />
      <view class="remove-button" data-index="{{index}}" bindtap="removeEducation">删除</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head"><text class="section-title no-border">工作经历</text><view class="circle-add" bindtap="addWorkExperience">+</view></view>
    <view class="experience-form" wx:for="{{card.workExperience}}" wx:key="index">
      <view class="year-row"><input class="input" placeholder="开始年" value="{{item.startYear}}" data-index="{{index}}" data-field="startYear" bindinput="setWorkField" /><input class="input" placeholder="结束年" value="{{item.endYear}}" data-index="{{index}}" data-field="endYear" bindinput="setWorkField" /></view>
      <input class="input" placeholder="公司/单位" value="{{item.company}}" data-index="{{index}}" data-field="company" bindinput="setWorkField" />
      <input class="input" placeholder="任职" value="{{item.position}}" data-index="{{index}}" data-field="position" bindinput="setWorkField" />
      <view class="remove-button" data-index="{{index}}" bindtap="removeWorkExperience">删除</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head"><text class="section-title no-border">社会职务</text><view class="circle-add" bindtap="addSocialPosition">+</view></view>
    <view class="experience-form" wx:for="{{card.socialPositions}}" wx:key="index">
      <input class="input" placeholder="机构" value="{{item.organization}}" data-index="{{index}}" data-field="organization" bindinput="setSocialField" />
      <input class="input" placeholder="任职" value="{{item.position}}" data-index="{{index}}" data-field="position" bindinput="setSocialField" />
      <view class="remove-button" data-index="{{index}}" bindtap="removeSocialPosition">删除</view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">其他</text>
    <view class="form-item"><text class="label">标签</text><input class="input" value="{{card.tags}}" data-field="tags" bindinput="setField" placeholder="多个标签可用逗号隔开" /></view>
    <textarea class="textarea block" value="{{card.remark}}" data-field="remark" bindinput="setField" placeholder="备注" />
  </view>

  <view class="submit-button" bindtap="onSubmit">保存</view>
</view>
