.container { background:#f5f6f7; min-height:100vh; padding:24rpx 0 120rpx; }
.section { background:#fff; margin:0 24rpx 24rpx; padding:28rpx; border-radius:18rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,.03); }
.section-title { display:block; font-size:31rpx; font-weight:700; color:#222; margin-bottom:20rpx; padding-bottom:14rpx; border-bottom:1rpx solid #eee; }
.section-title.no-border { margin:0; padding:0; border:0; }
.section-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:20rpx; }
.section-head.mt { margin-top:22rpx; }
.circle-add { width:56rpx; height:56rpx; border-radius:50%; background:#07c160; color:#fff; display:flex; align-items:center; justify-content:center; font-size:38rpx; font-weight:500; }
.avatar-uploader { width:180rpx; height:180rpx; border-radius:18rpx; border:2rpx dashed #cfd5dc; margin:0 auto 28rpx; display:flex; align-items:center; justify-content:center; overflow:hidden; background:#fafafa; }
.avatar-preview { width:100%; height:100%; }
.avatar-empty { color:#07c160; display:flex; flex-direction:column; align-items:center; font-size:24rpx; }
.avatar-empty .plus { font-size:56rpx; line-height:60rpx; }
.year-row { display:flex; gap:12rpx; }
.form-item { display:flex; align-items:center; margin-bottom:18rpx; }
.label { width:150rpx; flex-shrink:0; font-size:27rpx; color:#666; }
.input { flex:1; min-height:72rpx; font-size:28rpx; padding:0 18rpx; border:1rpx solid #e5e7eb; border-radius:14rpx; background:#fff; box-sizing:border-box; }
.textarea { width:100%; min-height:120rpx; font-size:28rpx; padding:18rpx; border:1rpx solid #e5e7eb; border-radius:14rpx; background:#fff; box-sizing:border-box; margin-bottom:14rpx; }
.textarea.block { margin-top:8rpx; }
.picker { flex:1; min-height:72rpx; line-height:72rpx; padding:0 18rpx; border:1rpx solid #e5e7eb; border-radius:14rpx; color:#333; }
.array-row { display:flex; gap:12rpx; align-items:center; margin-bottom:14rpx; }
.small-btn { width:76rpx; height:64rpx; border-radius:32rpx; display:flex; align-items:center; justify-content:center; font-size:26rpx; }
.small-btn.muted { background:#eef0f2; color:#777; }
.add-button { display:flex; align-items:center; justify-content:center; min-height:68rpx; margin:14rpx 0 20rpx; border:2rpx dashed #cfd5dc; border-radius:14rpx; color:#07c160; font-size:28rpx; background:#fafafa; }
.experience-form { border:1rpx solid #eef0f2; border-radius:16rpx; padding:18rpx; margin-bottom:18rpx; background:#f8fafc; }
.experience-form .input { width:100%; margin-bottom:14rpx; }
.remove-button { height:64rpx; border-radius:32rpx; background:#eef0f2; color:#777; display:flex; align-items:center; justify-content:center; font-size:26rpx; margin-top:4rpx; }
.submit-button { position:fixed; left:24rpx; right:24rpx; bottom:34rpx; height:82rpx; line-height:82rpx; background:#07c160; color:#fff; text-align:center; border-radius:44rpx; font-size:31rpx; font-weight:700; box-shadow:0 8rpx 24rpx rgba(7,193,96,.28); }
