.container {
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

.section {
  background-color: #ffffff;
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #eee;
}

.form-item {
  display: flex;
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #555;
  width: 120rpx;
}

.input {
  flex: 1;
  font-size: 28rpx;
  padding: 10rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
}

.textarea {
  flex: 1;
  font-size: 28rpx;
  padding: 10rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  height: 100rpx;
}

.radio-group {
  display: flex;
  flex-wrap: wrap;
  flex: 1;
}

.radio-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  margin-bottom: 10rpx;
}

.radio-item text {
  font-size: 28rpx;
  color: #333;
}

.add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin: 20rpx 0;
  border: 2rpx dashed #ccc;
  border-radius: 8rpx;
  background-color: #f9f9f9;
}

.add-button text {
  font-size: 28rpx;
  color: #07c160;
  margin-left: 10rpx;
}

.experience-item {
  margin-bottom: 20rpx;
}

.experience-form {
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background-color: #fafafa;
}

.remove-button {
  text-align: center;
  margin-top: 10rpx;
}

.remove-button text {
  color: #ff0000;
  font-size: 26rpx;
}

.submit-button {
  margin: 40rpx 30rpx;
  padding: 20rpx;
  background-color: #07c160;
  color: white;
  text-align: center;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
}