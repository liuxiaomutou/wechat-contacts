.container {
  background-color: #f5f5f5;
  height: 100vh;
}

.header {
  display: flex;
  justify-content: center;
  padding: 40rpx 30rpx;
  background-color: #ffffff;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.visibility-scroll {
  height: calc(100vh - 200rpx);
}

.visibility-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #ffffff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.field-name {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

.visibility-picker {
  width: 200rpx;
}

.visibility-picker text {
  font-size: 28rpx;
  color: #666;
}

.submit-button {
  margin: 40rpx 30rpx;
  padding: 20rpx;
  background-color: #07c160;
  color: white;
  text-align: center;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
}