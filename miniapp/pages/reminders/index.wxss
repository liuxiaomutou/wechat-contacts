.container { min-height:100vh; background:#f5f6f7; padding:24rpx; box-sizing:border-box; }
.card { background:#fff; border-radius:18rpx; padding:28rpx; margin-bottom:24rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,.03); }
.row { display:flex; align-items:center; justify-content:space-between; }
.title { font-size:34rpx; font-weight:700; color:#222; margin-bottom:8rpx; }
.desc, .tips, .muted { color:#888; font-size:24rpx; line-height:1.5; }
.label { font-size:30rpx; font-weight:700; color:#333; margin-bottom:18rpx; }
.picker, .input { min-height:76rpx; border:1rpx solid #e5e7eb; border-radius:14rpx; padding:0 20rpx; display:flex; align-items:center; font-size:28rpx; box-sizing:border-box; }
.check-row { display:flex; align-items:center; gap:16rpx; padding:18rpx 0; font-size:28rpx; color:#333; }
.btn-row { display:flex; gap:18rpx; margin-top:20rpx; }
.btn { flex:1; font-size:28rpx; background:#f2f4f5; color:#333; border-radius:14rpx; }
.btn.primary { background:#07c160; color:#fff; }
.empty { color:#aaa; font-size:26rpx; padding:16rpx 0; }
.log { padding:18rpx 0; border-bottom:1rpx solid #f0f0f0; font-size:27rpx; color:#333; }
.log:last-child { border-bottom:0; }
