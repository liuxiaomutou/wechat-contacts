<!-- 名片详情页 -->
<view class="container">
  <!-- 头部信息 -->
  <view class="header">
    <view class="avatar">{{card.name.charAt(0)}}</view>
    <view class="info">
      <text class="name">{{card.name}}</text>
      <text class="company-title">{{card.company}} | {{card.title}}</text>
    </view>
  </view>
  
  <!-- 基本信息 -->
  <view class="section">
    <text class="section-title">基本信息</text>
    <view class="info-item">
      <text class="label">手机号:</text>
      <text class="value" bindtap="callPhone">{{card.phone}}</text>
    </view>
    <view class="info-item">
      <text class="label">微信:</text>
      <text class="value" bindtap="copyWechat">{{card.wechat}}</text>
    </view>
    <view class="info-item">
      <text class="label">邮箱:</text>
      <text class="value">{{card.email}}</text>
    </view>
  </view>
  
  <!-- 工作信息 -->
  <view class="section">
    <text class="section-title">工作信息</text>
    <view class="info-item">
      <text class="label">行业:</text>
      <text class="value">{{card.industry}}</text>
    </view>
    <view class="info-item">
      <text class="label">领域:</text>
      <text class="value">{{card.field}}</text>
    </view>
    <view class="info-item">
      <text class="label">级别:</text>
      <text class="value">{{card.level}}</text>
    </view>
  </view>
  
  <!-- 个人资料 -->
  <view class="section">
    <text class="section-title">个人资料</text>
    <view class="info-item">
      <text class="label">籍贯:</text>
      <text class="value">{{card.hometown}}</text>
    </view>
    <view class="info-item">
      <text class="label">住宅地址:</text>
      <text class="value">{{card.residence}}</text>
    </view>
    <view class="info-item">
      <text class="label">老家地址:</text>
      <text class="value">{{card.originalResidence}}</text>
    </view>
  </view>
  
  <!-- 教育经历 -->
  <view class="section" wx:if="{{card.education && card.education.length > 0}}">
    <text class="section-title">教育经历</text>
    <view class="experience-item" wx:for="{{card.education}}" wx:key="index">
      <text class="experience-text">{{item.school}} - {{item.major}} ({{item.degree}})</text>
      <text class="experience-date">{{item.startDate}} - {{item.endDate}}</text>
    </view>
  </view>
  
  <!-- 工作经历 -->
  <view class="section" wx:if="{{card.workExperience && card.workExperience.length > 0}}">
    <text class="section-title">工作经历</text>
    <view class="experience-item" wx:for="{{card.workExperience}}" wx:key="index">
      <text class="experience-text">{{item.company}} - {{item.position}} ({{item.department}})</text>
      <text class="experience-date">{{item.startDate}} - {{item.endDate}}</text>
      <text class="experience-desc">{{item.description}}</text>
    </view>
  </view>
  
  <!-- 社会职务 -->
  <view class="section" wx:if="{{card.socialRoles && card.socialRoles.length > 0}}">
    <text class="section-title">社会职务</text>
    <view class="experience-item" wx:for="{{card.socialRoles}}" wx:key="index">
      <text class="experience-text">{{item.organization}} - {{item.position}}</text>
      <text class="experience-date">{{item.startDate}} - {{item.endDate}}</text>
    </view>
  </view>
  
  <!-- 底部操作 -->
  <view class="actions" wx:if="{{canEdit}}">
    <view class="action-button" bindtap="onEditCard">
      <text>编辑</text>
    </view>
    <view class="action-button" bindtap="onSetVisibility">
      <text>设置可见性</text>
    </view>
    <view class="action-button" bindtap="onDeleteCard">
      <text>删除</text>
    </view>
  </view>
</view>