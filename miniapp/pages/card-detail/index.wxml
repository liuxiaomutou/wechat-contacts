<view class="container">
  <!-- 确认删除弹窗 -->
  <view class="overlay" wx:if="{{showConfirm}}">
    <view class="dialog">
      <text class="dialog-title">确认删除</text>
      <text class="dialog-body">确定要删除该名片吗？删除后无法恢复。</text>
      <view class="dialog-buttons">
        <view class="dialog-btn cancel" bindtap="closeConfirm">取消</view>
        <view class="dialog-btn danger" bindtap="confirmDelete">删除</view>
      </view>
    </view>
  </view>

  <!-- 头部 -->
  <view class="header">
    <image wx:if="{{card.avatar}}" class="header-avatar" src="{{card.avatar}}" mode="aspectFill" />
    <view wx:else class="header-avatar header-initial">{{card.initial}}</view>
    <text class="header-name">{{card.name}}</text>
    <text wx:if="{{card.company || card.position}}" class="header-sub">{{[card.company, card.position].filter(Boolean).join(' · ')}}</text>
    <view class="header-tags">
      <text wx:if="{{card.gender}}" class="tag">{{card.gender === 'male' ? '男' : card.gender === 'female' ? '女' : card.gender}}</text>
      <text wx:if="{{card.field}}" class="tag">{{card.field}}</text>
      <text wx:if="{{card.industry}}" class="tag">{{card.industry}}</text>
    </view>
    <view class="header-actions" wx:if="{{canEdit || canSetVisibility || canDelete}}">
      <view class="action-btn" wx:if="{{canEdit}}" bindtap="onEditCard">✏️ 编辑</view>
      <view class="action-btn" wx:if="{{canSetVisibility}}" bindtap="onSetVisibility">👁 可见</view>
      <view class="action-btn danger" wx:if="{{canDelete}}" bindtap="onDeleteCard">🗑 删除</view>
    </view>
  </view>

  <!-- 电话 -->
  <view class="section" wx:if="{{phones.length}}">
    <text class="section-title">电话</text>
    <view class="entry-row" wx:for="{{phones}}" wx:key="index" data-value="{{item.value}}" bindtap="callPhone" data-phone="{{item.value}}">
      <text wx:if="{{item.label}}" class="entry-label">{{item.label}}</text>
      <text class="entry-value phone-value">{{item.value}}</text>
      <text class="entry-action call-icon">📞</text>
    </view>
  </view>

  <!-- 邮箱 -->
  <view class="section" wx:if="{{emails.length}}">
    <text class="section-title">邮箱</text>
    <view class="entry-row" wx:for="{{emails}}" wx:key="index" data-value="{{item.value}}" bindtap="copyValue">
      <text wx:if="{{item.label}}" class="entry-label">{{item.label}}</text>
      <text class="entry-value email-value">{{item.value}}</text>
      <text class="entry-action copy-icon">📋</text>
    </view>
  </view>

  <!-- 地址 -->
  <view class="section" wx:if="{{addresses.length}}">
    <text class="section-title">地址</text>
    <view class="entry-row" wx:for="{{addresses}}" wx:key="index" data-value="{{item.addressText}}" bindtap="copyValue">
      <text wx:if="{{item.label}}" class="entry-label">{{item.label}}</text>
      <view class="entry-value-block">
        <text class="address-region" wx:if="{{item.province || item.city || item.district}}">
          {{[item.province, item.city, item.district].filter(Boolean).join(' ')}}
        </text>
        <text class="address-detail" wx:if="{{item.detail}}">{{item.detail}}</text>
      </view>
      <text class="entry-action copy-icon">📋</text>
    </view>
  </view>

  <!-- 微信 -->
  <view class="section" wx:if="{{card.wechat}}">
    <text class="section-title">微信</text>
    <view class="entry-row" data-value="{{card.wechat}}" bindtap="copyValue">
      <text class="entry-value">{{card.wechat}}</text>
      <text class="entry-action copy-icon">📋</text>
    </view>
  </view>

  <!-- 生日 -->
  <view class="section" wx:if="{{card.solarBirthday || card.lunarBirthday}}">
    <text class="section-title">生日</text>
    <view class="entry-row" wx:if="{{card.solarBirthday}}">
      <text class="entry-label">阳历</text>
      <text class="entry-value">{{card.solarBirthday}}</text>
    </view>
    <view class="entry-row" wx:if="{{card.lunarBirthday}}">
      <text class="entry-label">农历</text>
      <text class="entry-value">{{card.lunarBirthday}}</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section" wx:if="{{card.ethnicity || card.birthplace || card.maritalStatus || card.qq || card.website}}">
    <text class="section-title">详细信息</text>
    <view class="info-grid">
      <view class="info-item" wx:if="{{card.ethnicity}}"><text class="info-label">民族</text><text class="info-value">{{card.ethnicity}}</text></view>
      <view class="info-item" wx:if="{{card.birthplace}}"><text class="info-label">籍贯</text><text class="info-value">{{card.birthplace}}</text></view>
      <view class="info-item" wx:if="{{card.maritalStatus}}"><text class="info-label">婚姻</text><text class="info-value">{{card.maritalStatus}}</text></view>
      <view class="info-item" wx:if="{{card.tags}}"><text class="info-label">标签</text><text class="info-value">{{card.tags}}</text></view>
    </view>
    <view class="entry-row" wx:if="{{card.qq}}" data-value="{{card.qq}}" bindtap="copyValue"><text class="entry-label">QQ</text><text class="entry-value">{{card.qq}}</text></view>
    <view class="entry-row" wx:if="{{card.website}}" data-value="{{card.website}}" bindtap="copyValue"><text class="entry-label">网站</text><text class="entry-value">{{card.website}}</text></view>
  </view>

  <!-- 教育经历 -->
  <view class="section" wx:if="{{education.length}}">
    <text class="section-title">教育经历</text>
    <view class="list-item" wx:for="{{education}}" wx:key="index">
      <text class="list-year">{{item.startYear}}-{{item.endYear || '至今'}}</text>
      <text class="list-title">{{item.school}}</text>
      <text wx:if="{{item.degree}}" class="list-sub">{{item.degree}}</text>
    </view>
  </view>

  <!-- 工作经历 -->
  <view class="section" wx:if="{{workExperience.length}}">
    <text class="section-title">工作经历</text>
    <view class="list-item" wx:for="{{workExperience}}" wx:key="index">
      <text class="list-year">{{item.startYear}}-{{item.endYear || '至今'}}</text>
      <text class="list-title">{{item.company}}</text>
      <text wx:if="{{item.position}}" class="list-sub">{{item.position}}</text>
    </view>
  </view>

  <!-- 社会职务 -->
  <view class="section" wx:if="{{socialPositions.length}}">
    <text class="section-title">社会职务</text>
    <view class="list-item" wx:for="{{socialPositions}}" wx:key="index">
      <text class="list-title">{{item.organization}}</text>
      <text wx:if="{{item.position}}" class="list-sub">{{item.position}}</text>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section" wx:if="{{card.remark}}">
    <text class="section-title">备注</text>
    <text class="remark-text">{{card.remark}}</text>
  </view>
</view>
