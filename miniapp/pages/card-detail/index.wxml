<view class="container">
  <view class="header">
    <view class="avatar" wx:if="{{!card.avatar}}">{{card.initial}}</view>
    <image class="avatar image" wx:else src="{{card.avatar}}" mode="aspectFill" />
    <view class="info">
      <text class="name">{{card.name}}</text>
      <text class="company-title" wx:if="{{card.company || card.position}}">{{card.company || ''}}{{card.company && card.position ? ' · ' : ''}}{{card.position || ''}}</text>
      <text class="role-tag">{{card.role || 'viewer'}}</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">基本信息</text>
    <view class="info-item" wx:if="{{card.gender}}"><text class="label">性别</text><text class="value">{{card.gender}}</text></view>
    <view class="info-item" wx:if="{{card.company}}"><text class="label">工作单位</text><text class="value">{{card.company}}</text></view>
    <view class="info-item" wx:if="{{card.position}}"><text class="label">职位</text><text class="value">{{card.position}}</text></view>
    <view class="info-item" wx:if="{{card.industry}}"><text class="label">行业</text><text class="value">{{card.industry}}</text></view>
    <view class="info-item" wx:if="{{card.field}}"><text class="label">领域</text><text class="value">{{card.field}}</text></view>
  </view>

  <view class="section" wx:if="{{phones.length || emails.length || card.wechat || card.qq}}">
    <text class="section-title">联系方式</text>
    <view class="info-item" wx:for="{{phones}}" wx:key="index" wx:for-item="phone"><text class="label">电话{{index + 1}}</text><text class="value link" data-phone="{{phone}}" bindtap="callPhone">{{phone}}</text></view>
    <view class="info-item" wx:for="{{emails}}" wx:key="index" wx:for-item="email"><text class="label">邮箱{{index + 1}}</text><text class="value link" data-value="{{email}}" bindtap="copyValue">{{email}}</text></view>
    <view class="info-item" wx:if="{{card.wechat}}"><text class="label">微信</text><text class="value link" data-value="{{card.wechat}}" bindtap="copyValue">{{card.wechat}}</text></view>
    <view class="info-item" wx:if="{{card.qq}}"><text class="label">QQ</text><text class="value">{{card.qq}}</text></view>
  </view>

  <view class="section" wx:if="{{card.solarBirthday || card.lunarBirthday || card.ethnicity || card.birthplace || card.maritalStatus}}">
    <text class="section-title">生日与身份</text>
    <view class="info-item" wx:if="{{card.solarBirthday}}"><text class="label">阳历生日</text><text class="value">{{card.solarBirthday}}</text></view>
    <view class="info-item" wx:if="{{card.lunarBirthday}}"><text class="label">农历生日</text><text class="value">{{card.lunarBirthday}}</text></view>
    <view class="info-item" wx:if="{{card.ethnicity}}"><text class="label">民族</text><text class="value">{{card.ethnicity}}</text></view>
    <view class="info-item" wx:if="{{card.birthplace}}"><text class="label">籍贯</text><text class="value">{{card.birthplace}}</text></view>
    <view class="info-item" wx:if="{{card.maritalStatus}}"><text class="label">婚姻</text><text class="value">{{card.maritalStatus}}</text></view>
  </view>

  <view class="section" wx:if="{{card.province || card.city || card.district || card.township || card.detailAddress}}">
    <text class="section-title">地址</text>
    <view class="info-item"><text class="label">地址</text><text class="value">{{card.province || ''}}{{card.city || ''}}{{card.district || ''}}{{card.township || ''}}{{card.detailAddress || ''}}</text></view>
  </view>

  <view class="section" wx:if="{{education.length > 0}}">
    <text class="section-title">教育经历</text>
    <view class="experience-item" wx:for="{{education}}" wx:key="index">
      <text class="experience-date">{{item.startYear || item.startDate}} - {{item.endYear || item.endDate}}</text>
      <text class="experience-text">{{item.school}} {{item.degree}}</text>
    </view>
  </view>

  <view class="section" wx:if="{{workExperience.length > 0}}">
    <text class="section-title">工作经历</text>
    <view class="experience-item" wx:for="{{workExperience}}" wx:key="index">
      <text class="experience-date">{{item.startYear || item.startDate}} - {{item.endYear || item.endDate}}</text>
      <text class="experience-text">{{item.company}} {{item.position}}</text>
    </view>
  </view>

  <view class="section" wx:if="{{socialPositions.length > 0}}">
    <text class="section-title">社会职务</text>
    <view class="experience-item" wx:for="{{socialPositions}}" wx:key="index"><text class="experience-text">{{item.organization}} {{item.position}}</text></view>
  </view>

  <view class="section" wx:if="{{card.tags || card.remark}}">
    <text class="section-title">其他</text>
    <view class="info-item" wx:if="{{card.tags}}"><text class="label">标签</text><text class="value">{{card.tags}}</text></view>
    <view class="info-item" wx:if="{{card.remark}}"><text class="label">备注</text><text class="value">{{card.remark}}</text></view>
  </view>

  <view class="actions" wx:if="{{canEdit || canSetVisibility || canDelete}}">
    <view class="action-button primary" wx:if="{{canEdit}}" bindtap="onEditCard"><text>编辑</text></view>
    <view class="action-button" wx:if="{{canSetVisibility}}" bindtap="onSetVisibility"><text>可见性</text></view>
    <view class="action-button muted" wx:if="{{canDelete}}" bindtap="onDeleteCard"><text>删除</text></view>
  </view>

  <view class="confirm-mask" wx:if="{{showConfirm}}" bindtap="closeConfirm"></view>
  <view class="confirm-layer" wx:if="{{showConfirm}}">
    <text class="confirm-title">删除名片</text>
    <text class="confirm-text">删除是低频操作。确定删除这张名片吗？</text>
    <view class="confirm-actions"><view class="confirm-btn cancel" bindtap="closeConfirm">取消</view><view class="confirm-btn ok" bindtap="confirmDelete">确认删除</view></view>
  </view>
</view>
