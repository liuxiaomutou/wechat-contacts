.container { background-color:#f5f6f7; min-height:100vh; padding-bottom:120rpx; }
.header { display:flex; align-items:center; padding:44rpx 32rpx; background:#fff; margin-bottom:24rpx; }
.avatar { width:124rpx; height:124rpx; border-radius:50%; background:#07c160; color:#fff; display:flex; align-items:center; justify-content:center; font-size:56rpx; font-weight:700; margin-right:28rpx; overflow:hidden; }
.avatar.image { background:#f2f2f2; }
.info { flex:1; min-width:0; }
.name { display:block; font-size:38rpx; font-weight:700; color:#222; margin-bottom:10rpx; }
.company-title { display:block; font-size:28rpx; color:#666; margin-bottom:10rpx; }
.role-tag { display:inline-block; color:#07c160; background:#e8f5e8; font-size:22rpx; padding:4rpx 14rpx; border-radius:18rpx; }
.section { background:#fff; margin:0 24rpx 24rpx; padding:28rpx; border-radius:18rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,.03); }
.section-title { display:block; font-size:31rpx; font-weight:700; color:#222; margin-bottom:20rpx; padding-bottom:14rpx; border-bottom:1rpx solid #eee; }
.info-item { display:flex; align-items:flex-start; margin-bottom:18rpx; line-height:1.55; }
.info-item:last-child { margin-bottom:0; }
.label { width:150rpx; flex-shrink:0; font-size:27rpx; color:#888; }
.value { flex:1; font-size:28rpx; color:#333; word-break:break-all; }
.value.link { color:#07c160; }
.experience-item { background:#f8fafc; border-radius:14rpx; padding:18rpx; margin-bottom:16rpx; }
.experience-text { display:block; font-size:28rpx; color:#333; font-weight:500; margin-bottom:8rpx; }
.experience-date { display:block; font-size:25rpx; color:#888; margin-bottom:6rpx; }
.experience-desc { display:block; font-size:26rpx; color:#666; line-height:1.5; }
.actions { position:fixed; left:0; right:0; bottom:0; display:flex; gap:16rpx; padding:18rpx 24rpx 36rpx; background:rgba(255,255,255,.96); box-shadow:0 -4rpx 18rpx rgba(0,0,0,.06); }
.action-button { flex:1; height:76rpx; border-radius:40rpx; background:#f1f3f5; display:flex; align-items:center; justify-content:center; }
.action-button text { font-size:28rpx; color:#555; }
.action-button.primary { background:#07c160; }
.action-button.primary text { color:#fff; font-weight:600; }
.action-button.muted { background:#eef0f2; }
.action-button.muted text { color:#777; }
.confirm-mask { position:fixed; inset:0; background:rgba(0,0,0,.38); z-index:50; }
.confirm-layer { position:fixed; left:48rpx; right:48rpx; top:38%; background:#fff; border-radius:24rpx; padding:34rpx; z-index:51; box-shadow:0 12rpx 50rpx rgba(0,0,0,.18); }
.confirm-title { display:block; font-size:34rpx; font-weight:700; color:#222; margin-bottom:16rpx; }
.confirm-text { display:block; font-size:28rpx; color:#666; line-height:1.6; margin-bottom:28rpx; }
.confirm-actions { display:flex; gap:16rpx; }
.confirm-btn { flex:1; height:72rpx; border-radius:36rpx; display:flex; align-items:center; justify-content:center; font-size:28rpx; }
.confirm-btn.cancel { background:#f1f3f5; color:#555; }
.confirm-btn.ok { background:#07c160; color:#fff; font-weight:600; }
