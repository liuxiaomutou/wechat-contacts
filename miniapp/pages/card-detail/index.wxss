.container { background:#f5f6f7; min-height:100vh; padding-bottom:60rpx; }
.overlay { position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:100; display:flex; align-items:center; justify-content:center; }
.dialog { width:560rpx; background:#fff; border-radius:24rpx; padding:36rpx; box-shadow:0 16rpx 48rpx rgba(0,0,0,.12); }
.dialog-title { display:block; font-size:31rpx; font-weight:700; color:#222; text-align:center; }
.dialog-body { display:block; margin:20rpx 0 32rpx; text-align:center; font-size:28rpx; color:#666; line-height:1.6; }
.dialog-buttons { display:flex; gap:16rpx; }
.dialog-btn { flex:1; height:72rpx; line-height:72rpx; border-radius:36rpx; text-align:center; font-size:28rpx; font-weight:600; }
.dialog-btn.cancel { background:#eef0f2; color:#333; }
.dialog-btn.danger { background:#e54c42; color:#fff; }

/* 头部 */
.header { background:#fff; margin:0 0 20rpx; padding:40rpx 32rpx 28rpx; display:flex; flex-direction:column; align-items:center; }
.header-avatar { width:160rpx; height:160rpx; border-radius:50%; margin-bottom:20rpx; }
.header-avatar.header-initial { background:#07c160; color:#fff; font-size:60rpx; display:flex; align-items:center; justify-content:center; }
.header-name { font-size:34rpx; font-weight:700; color:#222; }
.header-sub { font-size:28rpx; color:#666; margin-top:6rpx; }
.header-tags { display:flex; gap:10rpx; margin-top:12rpx; flex-wrap:wrap; justify-content:center; }
.tag { background:#eef0f2; padding:6rpx 18rpx; border-radius:20rpx; font-size:24rpx; color:#555; }
.header-actions { display:flex; gap:16rpx; margin-top:22rpx; }
.action-btn { padding:0 24rpx; height:58rpx; line-height:58rpx; border-radius:29rpx; font-size:26rpx; font-weight:500; background:#07c160; color:#fff; }
.action-btn.danger { background:#e54c42; }

/* 区块 */
.section { background:#fff; padding:28rpx 32rpx; margin-bottom:16rpx; }
.section-title { display:block; font-size:29rpx; font-weight:700; color:#222; padding-bottom:14rpx; margin-bottom:16rpx; border-bottom:1rpx solid #eee; }

/* 条目行 */
.entry-row { display:flex; align-items:flex-start; padding:14rpx 0; border-bottom:1rpx solid #f5f5f5; }
.entry-row:last-child { border-bottom:0; }
.entry-label { background:#e8f5e9; color:#07c160; font-size:24rpx; padding:2rpx 14rpx; border-radius:6rpx; margin-right:14rpx; flex-shrink:0; margin-top:3rpx; }
.entry-value { flex:1; font-size:28rpx; color:#333; word-break:break-all; line-height:1.6; }
.entry-value-block { flex:1; }
.address-region { display:block; font-size:27rpx; color:#555; }
.address-detail { display:block; font-size:27rpx; color:#333; margin-top:2rpx; }
.phone-value { font-size:30rpx; font-weight:500; }
.email-value { color:#07c160; }
.entry-action { flex-shrink:0; margin-left:14rpx; font-size:30rpx; opacity:.6; }

/* 信息网格 */
.info-grid { display:grid; grid-template-columns:1fr 1fr; gap:14rpx; margin-bottom:8rpx; }
.info-item { display:flex; flex-direction:column; background:#fafafa; border-radius:12rpx; padding:12rpx 16rpx; }
.info-label { font-size:24rpx; color:#999; }
.info-value { font-size:28rpx; color:#333; margin-top:2rpx; }

/* 列表条目（教育/工作/社会职务） */
.list-item { padding:16rpx 0; border-bottom:1rpx solid #f5f5f5; }
.list-item:last-child { border-bottom:0; }
.list-year { font-size:24rpx; color:#999; }
.list-title { display:block; font-size:28rpx; color:#333; font-weight:500; margin-top:4rpx; }
.list-sub { display:block; font-size:26rpx; color:#666; margin-top:4rpx; }

/* 备注 */
.remark-text { display:block; font-size:27rpx; color:#555; line-height:1.7; }
