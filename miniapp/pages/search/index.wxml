<!-- pages/search/index.wxml -->
<view class="search-page">

  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <icon class="search-icon" type="search" size="14" color="#999"/>
      <input
        class="search-input"
        type="text"
        placeholder="搜索姓名/手机号"
        value="{{keyword}}"
        focus="{{focus}}"
        bindinput="onInput"
        confirm-type="search"
        auto-focus
      />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="onClear">
        <icon type="clear" size="14" color="#ccc"/>
      </view>
    </view>
  </view>

  <!-- 搜索结果提示 -->
  <view class="search-info" wx:if="{{hasSearched}}">
    <text class="search-info-text">共找到 {{results.length}} 条结果</text>
  </view>

  <!-- 联系人列表 -->
  <scroll-view
    class="search-results"
    scroll-y
    wx:if="{{results.length > 0}}"
  >
    <view
      class="card search-result-item"
      wx:for="{{results}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onContactTap"
    >
      <view class="search-result-avatar" style="background-color: {{item.color || '#4A90D9'}}">
        <text>{{item.name ? item.name[0] : '?'}}</text>
      </view>
      <view class="search-result-info">
        <view class="search-result-name">{{item.name}}</view>
        <view class="search-result-phone">{{item.phone}}</view>
      </view>
      <view class="search-result-arrow">›</view>
    </view>
  </scroll-view>

  <!-- 搜索前提示 -->
  <view class="empty-state" wx:elif="{{!hasSearched}}">
    <icon type="search" size="60" color="#ddd"/>
    <text class="empty-title">搜索联系人</text>
    <text class="empty-desc">输入姓名或手机号快速查找</text>
  </view>

  <!-- 无结果 -->
  <view class="empty-state" wx:elif="{{results.length === 0}}">
    <icon type="info" size="60" color="#ddd"/>
    <text class="empty-title">未找到联系人</text>
    <text class="empty-desc">试试其他关键词</text>
  </view>

</view>