.container {
  background-color: #f5f5f5;
  height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  position: relative;
}

.library-name {
  font-size: 32rpx;
  color: #333;
  flex: 1;
}

.search-input {
  flex: 2;
  margin: 0 20rpx;
  padding: 10rpx 20rpx;
  border-radius: 40rpx;
  border: 1rpx solid #ddd;
  font-size: 28rpx;
}

.add-button {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #07c160;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
}

.cards-scroll {
  height: calc(100vh - 120rpx);
}

.card-item {
  display: flex;
  padding: 30rpx;
  background-color: #ffffff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #07c160;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.card-info {
  flex: 1;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.company {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 26rpx;
  color: #07c160;
}

.empty-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}