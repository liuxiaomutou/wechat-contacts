<!-- 我的页面 -->
<view class="container">
  <!-- 顶部信息 -->
  <view class="profile-header">
    <image class="avatar" src="{{avatar}}" mode="aspectFill"></image>
    <view class="profile-info">
      <text class="nickname">{{nickname}}</text>
      <text class="role">{{role}}</text>
    </view>
  </view>
  
  <!-- 操作列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onSettings">
      <text>个人信息设置</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onBirthdayReminders">
      <text>生日提醒</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onServerSettings">
      <text>设置</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onLogout">
      <text>退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>
  
  <!-- 管理后台入口 (仅管理员可见) -->
  <view class="admin-section" wx:if="{{isAdmin}}">
    <view class="admin-item" bindtap="onAdminPanel">
      <text>管理后台</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>