<!-- 加载态 -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text>加载中...</text>
</view>

<!-- 联系人详情 -->
<view class="detail-page" wx:elif="{{contact}}">
  <!-- 头部区域：头像 + 姓名 -->
  <view class="detail-header">
    <view class="avatar-wrapper">
      <view class="avatar-circle" style="background-color: {{contact.color || '#07c160'}};">
        <text class="avatar-text">{{contact.name ? contact.name.charAt(0) : '?'}}</text>
      </view>
      <!-- 收藏星标 -->
      <view class="favorite-badge" wx:if="{{contact.favorite}}" bindtap="onFavoriteTap">
        <text class="icon-star-filled">★</text>
      </view>
      <view class="favorite-badge favorite-empty" wx:else bindtap="onFavoriteTap">
        <text class="icon-star">☆</text>
      </view>
    </view>
    <text class="detail-name">{{contact.name}}</text>
    <text class="detail-title" wx:if="{{contact.company || contact.position}}">
      {{contact.company}}{{contact.company && contact.position ? ' · ' : ''}}{{contact.position}}
    </text>
    <view class="group-tag-wrap">
      <view class="group-tag" wx:if="{{contact.groupName}}" style="background-color: {{contact.groupColor || '#e8f5e9'}}; color: {{contact.groupTextColor || '#2e7d32'}};">
        <text>{{contact.groupName}}</text>
      </view>
      <view class="group-tag" wx:elif="{{contact.group}}">
        <text>{{contact.group}}</text>
      </view>
    </view>
  </view>

  <!-- 信息卡片 -->
  <view class="card info-card">
    <!-- 手机号 -->
    <view class="info-row" wx:if="{{contact.phone}}" data-phone="{{contact.phone}}" bindtap="onPhoneTap">
      <view class="info-label">
        <text class="info-icon">📞</text>
        <text>手机</text>
      </view>
      <view class="info-value">
        <text>{{contact.phone}}</text>
        <text class="info-arrow">›</text>
      </view>
    </view>

    <!-- 邮箱 -->
    <view class="info-row" wx:if="{{contact.email}}">
      <view class="info-label">
        <text class="info-icon">✉️</text>
        <text>邮箱</text>
      </view>
      <view class="info-value">
        <text>{{contact.email}}</text>
      </view>
    </view>

    <!-- 公司 -->
    <view class="info-row" wx:if="{{contact.company}}">
      <view class="info-label">
        <text class="info-icon">🏢</text>
        <text>公司</text>
      </view>
      <view class="info-value">
        <text>{{contact.company}}</text>
      </view>
    </view>

    <!-- 职位 -->
    <view class="info-row" wx:if="{{contact.position}}">
      <view class="info-label">
        <text class="info-icon">💼</text>
        <text>职位</text>
      </view>
      <view class="info-value">
        <text>{{contact.position}}</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="info-row info-row-last" wx:if="{{contact.notes}}">
      <view class="info-label">
        <text class="info-icon">📝</text>
        <text>备注</text>
      </view>
      <view class="info-value info-value-multiline">
        <text>{{contact.notes}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <view class="action-btn" wx:if="{{contact.phone}}" data-phone="{{contact.phone}}" bindtap="onPhoneTap">
      <text class="action-icon">📞</text>
      <text class="action-text">打电话</text>
    </view>
    <view class="action-btn" wx:if="{{contact.phone}}" data-phone="{{contact.phone}}" bindtap="onSMSTap">
      <text class="action-icon">💬</text>
      <text class="action-text">发短信</text>
    </view>
    <view class="action-btn" bindtap="onEditTap">
      <text class="action-icon">✏️</text>
      <text class="action-text">编辑</text>
    </view>
    <view class="action-btn action-btn-danger" bindtap="onDeleteTap">
      <text class="action-icon">🗑️</text>
      <text class="action-text">删除</text>
    </view>
  </view>
</view>

<!-- 空状态 -->
<view class="empty-state" wx:else>
  <text class="empty-icon">😶</text>
  <text>联系人不存在</text>
</view>
