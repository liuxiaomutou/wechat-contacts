<view class="page">
  <!-- 导航栏 -->
  <view class="header">
    <view class="header-title">名片库</view>
    <view class="header-subtitle" wx:if="{{user}}">{{user.nickname}} 的工作台</view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="goToSearch">
      <text class="action-icon">🔍</text>
      <text class="action-label">搜索</text>
    </view>
    <view class="action-item" bindtap="showCreateDialog">
      <text class="action-icon">➕</text>
      <text class="action-label">创建</text>
    </view>
    <view class="action-item" bindtap="goToMerge">
      <text class="action-icon">🔄</text>
      <text class="action-label">查重</text>
    </view>
    <view class="action-item" bindtap="goToImport">
      <text class="action-icon">📥</text>
      <text class="action-label">导入</text>
    </view>
  </view>

  <!-- 名片库列表 -->
  <view class="section-title">我的名片库</view>
  <view wx:for="{{libraries}}" wx:key="id" class="lib-card" bindtap="goToLib" data-id="{{item.id}}">
    <view class="lib-avatar">{{item.name.slice(0,1)}}</view>
    <view class="lib-info">
      <view class="lib-name">{{item.name}}</view>
      <view class="lib-desc">{{item.description || item.role === 'admin' ? '管理员' : item.role}}</view>
    </view>
    <view class="lib-stats">
      <view class="stat-item">{{item._count?.cards || 0}} 张</view>
      <view class="stat-sub">{{item._count?.members || 1}} 人</view>
    </view>
    <view class="arrow">›</view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{libraries.length === 0 && !loading}}">
    <view class="empty-icon">📇</view>
    <view class="empty-text">还没有名片库</view>
    <button class="btn-primary" bindtap="showCreateDialog">创建名片库</button>
  </view>

  <!-- 创建对话框 -->
  <view class="dialog-overlay" wx:if="{{showDialog}}" bindtap="hideDialog"></view>
  <view class="dialog" wx:if="{{showDialog}}">
    <view class="dialog-title">新建名片库</view>
    <input class="dialog-input" placeholder="名片库名称" value="{{newLibName}}" bindinput="onLibNameInput" />
    <input class="dialog-input" placeholder="描述（选填）" value="{{newLibDesc}}" bindinput="onLibDescInput" />
    <view class="dialog-btns">
      <button class="dialog-btn cancel" bindtap="hideDialog">取消</button>
      <button class="dialog-btn confirm" bindtap="createLibrary">创建</button>
    </view>
  </view>
</view>
