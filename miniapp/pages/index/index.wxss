.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}
.header{
  background: linear-gradient(135deg, #07c160, #06ad56);
  padding: 80rpx 40rpx 60rpx;
  color: #fff;
}
.header-title{
  font-size: 44rpx;
  font-weight: 700;
}
.header-subtitle{
  font-size: 26rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}
.quick-actions{
  display: flex;
  background: #fff;
  margin: -30rpx 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.action-item{
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.action-icon{
  font-size: 44rpx;
}
.action-label{
  font-size: 24rpx;
  color: #666;
}
.section-title{
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding: 24rpx 32rpx 16rpx;
}
.lib-card{
  background: #fff;
  margin: 0 24rpx 16rpx;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.lib-avatar{
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #e8f5e8;
  color: #07c160;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.lib-info{
  flex: 1;
  min-width: 0;
}
.lib-name{
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}
.lib-desc{
  font-size: 24rpx;
  color: #999;
}
.lib-stats{
  text-align: right;
  flex-shrink: 0;
}
.stat-item{
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.stat-sub{
  font-size: 22rpx;
  color: #bbb;
}
.arrow{
  color: #ccc;
  font-size: 36rpx;
  margin-left: 12rpx;
}
.empty{
  padding: 120rpx 40rpx;
  text-align: center;
}
.empty-icon{
  font-size: 100rpx;
  margin-bottom: 24rpx;
}
.empty-text{
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.btn-primary{
  width: 360rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #07c160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}
.dialog-overlay{
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}
.dialog{
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 32rpx;
  z-index: 100;
}
.dialog-title{
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
  text-align: center;
}
.dialog-input{
  width: 100%;
  height: 80rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}
.dialog-btns{
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}
.dialog-btn{
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}
.dialog-btn.cancel{
  background: #f5f5f5;
  color: #666;
}
.dialog-btn.confirm{
  background: #07c160;
  color: #fff;
}
