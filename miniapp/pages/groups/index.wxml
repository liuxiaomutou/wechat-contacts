<!-- 分组管理页 -->
<view class="container">
  <!-- 分组列表 -->
  <view class="group-list">
    <block wx:for="{{groups}}" wx:key="id">
      <view class="card group-card">
        <view class="group-info">
          <text class="group-name">{{item.name}}</text>
          <text class="contact-count">{{item.contactCount}} 个联系人</text>
        </view>
        <view class="group-actions">
          <button class="btn-primary btn-sm" bindtap="onEditTap" data-id="{{item.id}}">编辑</button>
          <button class="btn-danger btn-sm" bindtap="onDeleteTap" data-id="{{item.id}}">删除</button>
        </view>
      </view>
    </block>
    
    <!-- 空状态 -->
    <view wx:if="{{groups.length === 0}}" class="empty-state">
      <text>暂无分组</text>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="add-btn-container">
    <button class="btn-primary add-btn" bindtap="onAddTap">+</button>
  </view>

  <!-- 弹窗遮罩层 -->
  <view wx:if="{{showModal}}" class="modal-overlay" bindtap="onModalCancel">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{editGroup ? '编辑分组' : '新建分组'}}</text>
        <button class="btn-close" bindtap="onModalCancel">×</button>
      </view>
      
      <view class="modal-body">
        <input 
          class="modal-input" 
          placeholder="请输入分组名称" 
          value="{{modalName}}" 
          bindinput="onModalNameInput" 
          focus="{{showModal}}" 
        />
      </view>
      
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="onModalCancel">取消</button>
        <button class="btn-primary" bindtap="onModalConfirm">确认</button>
      </view>
    </view>
  </view>
</view>