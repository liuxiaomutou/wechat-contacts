.container {
  padding: 20rpx;
  background-color: #f8f9fa;
  min-height: 100vh;
}

.group-list {
  margin-top: 20rpx;
}

.group-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.group-info {
  flex: 1;
}

.group-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.contact-count {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.group-actions {
  display: flex;
  gap: 12rpx;
}

.btn-sm {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
}

.add-btn-container {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  z-index: 100;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  font-size: 48rpx;
  line-height: 80rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-content {
  background-color: white;
  border-radius: 16rpx;
  width: 80%;
  max-width: 500rpx;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.2);
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.btn-close {
  background: none;
  border: none;
  font-size: 48rpx;
  color: #999;
  padding: 0;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
}

.modal-body {
  padding: 32rpx;
}

.modal-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #eee;
}

.btn-secondary {
  background-color: #f1f1f1;
  color: #333;
  border-color: #ddd;
}

.btn-danger {
  background-color: #ff4757;
  border-color: #ff4757;
  color: white;
}

.empty-state {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}