.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #07c160 0%, #f5f5f5 40%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
.login-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06);
}
.logo {
  text-align: center;
  font-size: 80rpx;
  margin-bottom: 12rpx;
}
.title {
  text-align: center;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}
.subtitle{
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 48rpx;
}
.tab-bar{
  display: flex;
  margin-bottom: 36rpx;
  border-bottom: 2rpx solid #eee;
}
.tab-item{
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 30rpx;
  color: #999;
}
.tab-item.active{
  color: #07c160;
  border-bottom: 4rpx solid #07c160;
  font-weight: 600;
}
.input{
  width: 100%;
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  color: #333;
  box-sizing: border-box;
}
.btn-primary{
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 88rpx;
  margin-top: 16rpx;
  margin-bottom: 24rpx;
  border: none;
}
.btn-primary:active{
  background: #06ad56;
}
.switch{
  text-align: center;
  font-size: 26rpx;
  color: #07c160;
  padding: 16rpx;
}
